{
  "expo": {
    "name": "Budgies",
    "slug": "budgies-couple",
    "owner": "visionfit360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/login-image.png",
    "scheme": "budgies",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.codewithpixie.budgies",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/login-image.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/login-image.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Budgies to access your photos so you can upload shared memories.",
          "cameraPermission": "Allow Budgies to use your camera to take photos together."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/login-image.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9bc09374-45e0-484c-8fac-90be679bc556"
      }
    }
  }
}
